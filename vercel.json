{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/development-exit-finance",
      "destination": "/dev-exit",
      "permanent": false
    },
    {
      "source": "/apply",
      "destination": "/apply-now",
      "permanent": false
    },
    {
      "source": "/go/speed",
      "destination": "https://posfincapital.com/apply/speed?utm_source=facebook&utm_medium=paid&utm_campaign=speed-loan&utm_content=fb-short",
      "permanent": false
    },
    {
      "source": "/go/bridge",
      "destination": "https://posfincapital.com/apply/bridge?utm_source=facebook&utm_medium=paid&utm_campaign=bank-bridge&utm_content=fb-short",
      "permanent": false
    },
    {
      "source": "/go/dev",
      "destination": "https://posfincapital.com/apply/dev?utm_source=facebook&utm_medium=paid&utm_campaign=dev-finance&utm_content=fb-short",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/engine/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ]
}
