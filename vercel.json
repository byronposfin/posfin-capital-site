{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/development-exit-finance",
      "destination": "https://posfin-pages.vercel.app/dev-exit",
      "permanent": false
    },
    {
      "source": "/dev-exit",
      "destination": "https://posfin-pages.vercel.app/dev-exit",
      "permanent": false
    },
    {
      "source": "/development-finance",
      "destination": "https://posfin-pages.vercel.app/development-finance",
      "permanent": false
    },
    {
      "source": "/speed-loan",
      "destination": "https://posfin-pages.vercel.app/speed-loan",
      "permanent": false
    },
    {
      "source": "/main-loan",
      "destination": "https://posfin-pages.vercel.app/main-loan",
      "permanent": false
    },
    {
      "source": "/back-to-back",
      "destination": "https://posfin-pages.vercel.app/back-to-back",
      "permanent": false
    },
    {
      "source": "/apply",
      "destination": "/apply-now",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/engine/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ]
}