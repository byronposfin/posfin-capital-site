// api/dropbox-sign-webhook.js
export default function handler(req, res) {
  if (req.method !== 'POST') {
    return res.status(405).send('Method Not Allowed');
  }

  console.log('Dropbox Sign Webhook received:', req.body);

  // Dropbox Sign requires this exact response body to validate the webhook
  res.status(200).send('Hello API Event Received');
}
